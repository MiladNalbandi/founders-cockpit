# Copy to .env. In DEBUG=1 (default), missing secrets are auto-generated
# and persisted to backend/.dev_secrets.json (gitignored). In production
# (DEBUG=0) the server refuses to start unless DJANGO_SECRET_KEY and
# FERNET_KEY are set explicitly.

# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=*

# REQUIRED in production. Any sufficiently random string:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# DJANGO_SECRET_KEY=

# REQUIRED in production. Generate ONCE and keep it stable —
# rotating it invalidates every encrypted Anthropic key in the DB.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=

# Database — comment out POSTGRES_* to use the on-disk SQLite default.
# POSTGRES_DB=cockpit
# POSTGRES_USER=cockpit
# POSTGRES_PASSWORD=cockpit
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

# REDIS_URL=redis://127.0.0.1:6379/0

# Set this if you want to skip per-user keys (handy in solo-dev).
# ANTHROPIC_API_KEY=

# Default model per agent type.
# ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
# ANTHROPIC_BUDDY_MODEL=claude-opus-4-7

# Convenience for first-launch smoke (no Celery worker needed, no Redis channels).
# CELERY_EAGER=1
# CHANNELS_IN_MEMORY=1

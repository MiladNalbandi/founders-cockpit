# Copy to .env. Anything left commented falls back to dev defaults in settings.py.

# DJANGO_SECRET_KEY=change-me-in-prod
# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=*

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=

# Database — comment out POSTGRES_* to use the on-disk SQLite default.
# POSTGRES_DB=cockpit
# POSTGRES_USER=cockpit
# POSTGRES_PASSWORD=cockpit
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

# REDIS_URL=redis://127.0.0.1:6379/0

# Set this if you want to skip per-user keys (handy in solo-dev).
# ANTHROPIC_API_KEY=

# Default model per agent type.
# ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
# ANTHROPIC_BUDDY_MODEL=claude-opus-4-7

# Convenience for first-launch smoke (no Celery worker needed, no Redis channels).
# CELERY_EAGER=1
# CHANNELS_IN_MEMORY=1

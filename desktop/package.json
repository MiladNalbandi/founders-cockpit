{
  "name": "founders-cockpit",
  "version": "0.1.0",
  "private": true,
  "description": "Founder's Cockpit — desktop client for the multi-agent startup builder",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --host 127.0.0.1 --port 5183",
    "dev:electron": "wait-on tcp:127.0.0.1:5183 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development VITE_DEV_URL=http://127.0.0.1:5183 electron .",
    "build": "tsc -p electron/tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "reactflow": "^11.11.4",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^32.1.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "wait-on": "^8.0.0"
  }
}
